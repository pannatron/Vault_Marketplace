# Copy to .env.local and fill in to turn on REAL data.
# Without these, PSA prices fall back to a clearly-labeled model estimate.

# eBay Browse API — real graded (PSA) listings: real photos, real asking prices.
# Get keys (free): https://developer.ebay.com → create an app → Production keyset.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# Optional — eBay Partner Network campaign id → affiliate links + commission.
EBAY_CAMPAIGN_ID=

# tcgpricelookup.com — REAL graded PSA/BGS/CGC prices (7-day eBay avg).
# Graded data needs the Starter plan ($19.99/mo)+. Free tier = raw only.
# Get a key: https://tcgpricelookup.com/tcg-api
TCGPL_API_KEY=

# Optional — defaults shown.
# EBAY_MARKETPLACE=EBAY_US
# EBAY_ENV=production   # set to "sandbox" to hit eBay sandbox endpoints
